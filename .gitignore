# ============================================================
# TaskFlow — Root .gitignore
# ============================================================

# ── Python / Django ──────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg
*.egg-info/
dist/
build/
*.manifest
*.spec
pip-log.txt
pip-delete-this-directory.txt
.tox/
.coverage
.cache
*.mo
*.pot
db.sqlite3
*.sqlite3

# Virtual environments
venv/
env/
.venv/

# ── Node / React ─────────────────────────────────────────────
node_modules/
frontend/dist/
frontend/dist-ssr/

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ── Environment variables (NEVER commit these) ───────────────
.env
.env.local
.env.development
.env.production
backend/.env
frontend/.env

# Safe to commit (no secrets, just examples)
!.env.example
!backend/.env.example
!frontend/.env.example

# ── OS files ─────────────────────────────────────────────────
.DS_Store
Thumbs.db
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# ── IDE ──────────────────────────────────────────────────────
.vscode/
!.vscode/extensions.json
.idea/
